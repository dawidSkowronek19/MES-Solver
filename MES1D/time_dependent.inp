[ GRID ]
	x_start = 0.0
	x_end = 1.0
	Grow_Factor = 0.5
	A=10.0
	Integration_Order = 12
	Numb_Of_elements = 200

[ SOLVER ]
	work_type=time_dependent
	beta =0.25
	gamma= 0.5
	epsilon=1e-8
	omega=0.2
	t_max = 5.0
	dt=0.01
	du=0.001
	dx_save=0.01
	sh_func_deg=1

[ BOUNDARYCONDITIONS ]
	BC1 = Dirichlet/0/0.0
	BC2= Dirichlet/200/0.0

[ FUNCTIONS ]
	E=0.5
[ INITIALVALUES ]
	u=exp(-(x-0.5)*(x-0.5)*100)
	v = 0.0
